{
  "name": "codex-usage-dashboard",
  "description": "Local dashboard for Codex usage statistics from ~/.codex logs.",
  "private": false,
  "version": "1.0.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "node dev.mjs",
    "dev": "vite --host 127.0.0.1 --port 8765",
    "dev:all": "node dev.mjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 8765",
    "check": "node scripts/python-command.mjs dashboard_api.py --check"
  },
  "engines": {
    "node": ">=20",
    "python": ">=3.10"
  },
  "devDependencies": {
    "vite": "^8.0.14"
  }
}
